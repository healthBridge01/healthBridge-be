<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Your {{ app_name }} one-time password</title>
    <style>
      @media only screen and (max-width: 600px) {
        .email-outer {
          padding: 12px !important;
        }
        .content-section {
          padding: 20px !important;
          background-color: #ffffff !important;
        }
        .verify-button {
          padding: 14px 24px !important;
          font-size: 15px !important;
          margin: 0 0 12px !important;
        }
        .verify-text {
          padding: 3px 6px !important;
          font-size: 15px !important;
        }
        .otp-digit {
          padding: 10px 12px !important;
          font-size: 20px !important;
          margin: 4px !important;
        }
        .otp-wrapper {
          padding: 12px 8px !important;
          background-color: #f3f4f6 !important;
          border-radius: 12px !important;
        }
      }
    </style>
  </head>
  <body
    style="
      background-color: #e5e7eb;
      margin: 0;
      padding: 0;
      font-family: Geist, 'Helvetica Neue', Helvetica, Arial, sans-serif;
      color: #111827;
    "
  >
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td align="center">
          <table
            width="100%"
            cellpadding="0"
            cellspacing="0"
            border="0"
            class="email-outer"
            style="max-width: 600px; padding: 40px 20px; background: #ffffff"
          >
            <tr>
              <td align="center" style="padding: 30px 20px 20px">
                <img
                  alt="HealthBridge logo"
                  src="https://res.cloudinary.com/dvieev0ag/image/upload/fl_preserve_transparency/v1771272075/healthBridge_x7vff5.jpg?_s=public-apps"
                  width="200"
                  style="display: block; margin: 0 auto"
                />
              </td>
            </tr>

            <tr>
              <td
                class="verify-text"
                style="
                  background-color: #155eef;
                  color: #ffffff;
                  font-size: 16px;
                  font-weight: 700;
                  padding: 4px 8px;
                  border-top-left-radius: 8px;
                  border-top-right-radius: 8px;
                  text-align: center;
                "
              >
                One Time Password (OTP)
              </td>
            </tr>

            <tr>
              <td
                class="content-section"
                style="background-color: #f6f6f6; padding: 20px"
              >
                <p style="font-size: 16px; font-weight: 700; margin: 0 0 4px">
                  Hello {{ name }},
                </p>

                <p style="font-size: 15px; line-height: 24px; margin: 0 0 20px">
                  Your one-time verification code is
                </p>

                <table
                  class="otp-wrapper"
                  cellpadding="0"
                  cellspacing="0"
                  border="0"
                  role="presentation"
                  style="width: 100%; margin: 0 auto 24px; padding: 16px 0"
                >
                  <tr>
                    {% for digit in otp_digits %}
                    <td style="text-align: center">
                      <div
                        class="otp-digit"
                        style="
                          display: inline-block;
                          padding: 16px 32px;
                          font-size: 26px;
                          font-weight: 700;
                          color: #1e293b;
                          text-align: center;
                          background-color: #ffffff;
                          border: 2px solid #d1d5db;
                          border-radius: 10px;
                          margin: 0 6px;
                        "
                      >
                        {{ digit }}
                      </div>
                    </td>
                    {% endfor %}
                  </tr>
                </table>

                {% if reset_url %}
                <div style="text-align: center">
                  <a
                    class="verify-button"
                    href="{{ reset_url }}"
                    style="
                      background-color: #155eef;
                      color: #ffffff;
                      font-size: 16px;
                      font-weight: 600;
                      padding: 16px 32px;
                      border-radius: 8px;
                      text-decoration: none;
                      display: inline-block;
                      width: 100%;
                      text-align: center;
                      box-sizing: border-box;
                      margin-bottom: 12px;
                    "
                  >
                    Reset My Password
                  </a>
                </div>
                {% endif %}

                <p style="font-size: 14px; line-height: 22px; margin: 0 0 12px">
                  This code will expire shortly, so please use it as soon as
                  possible.
                </p>

                <p style="font-size: 14px; line-height: 22px; margin: 0 0 12px">
                  If you didn't request this code, you can safely ignore this
                  email.
                </p>

                <p style="font-size: 14px; line-height: 22px; margin: 0">
                  Stay safe,
                  <br />
                  {{ app_name }} Team
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
