<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Verify your {{ app_name }} account</title>
    <style>
      @media only screen and (max-width: 600px) {
        .email-outer {
          padding: 12px !important;
        }
        .email-container {
          width: 100% !important;
          border-width: 3px !important;
        }
        .header-text {
          font-size: 22px !important;
        }
        .banner {
          padding: 16px 20px !important;
          font-size: 18px !important;
        }
        .content-section {
          padding: 20px !important;
          background-color: #ffffff !important;
        }
        .verify-button {
          padding: 14px 24px !important;
          font-size: 15px !important;
          margin: 0 0 12px !important;
        }
        .verify-text {
          padding: 3px 6px !important;
          font-size: 15px !important;
        }
      }
    </style>
  </head>
  <body
    style="
      background-color: #e5e7eb;
      margin: 0;
      padding: 0;
      font-family: Geist, 'Helvetica Neue', Helvetica, Arial, sans-serif;
      color: #111827;
    "
  >
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td align="center">
          <table
            width="100%"
            cellpadding="0"
            cellspacing="0"
            border="0"
            class="email-outer"
            style="max-width: 600px; padding: 40px 20px; background: #ffffff"
          >
            <tr>
              <td align="center" style="padding: 30px 20px 20px">
                <img
                  alt="HealthBridge logo"
                  src="https://res.cloudinary.com/duye4a3ff/image/upload/v1771680984/healthBridge-logo_zmz4pn.png"
                  width="200"
                  style="display: block; margin: 0 auto"
                />
              </td>
            </tr>

            <tr>
              <td
                class="verify-text"
                style="
                  background-color: #155eef;
                  color: #ffffff;
                  font-size: 16px;
                  font-weight: 600;
                  padding: 4px 8px;
                  border-top-left-radius: 8px;
                  border-top-right-radius: 8px;
                  text-align: center;
                "
              >
                Verify My Account
              </td>
            </tr>

            <tr>
              <td
                class="content-section"
                style="background-color: #f6f6f6; padding: 20px"
              >
                <p style="font-size: 16px; font-weight: 700; margin: 0 0 4px">
                  Hello {{ name }},
                </p>

                <p style="font-size: 15px; line-height: 24px; margin: 0 0 16px">
                  Welcome to {{ app_name }}.
                  <br />
                  Please verify your email address to activate your account.
                </p>

                {% if code %}
                <div
                  style="
                    display: inline-block;
                    padding: 12px 18px;
                    font-size: 20px;
                    letter-spacing: 4px;
                    background: #ffffff;
                    border: 2px solid #d1d5db;
                    border-radius: 8px;
                    color: #111827;
                    font-weight: 700;
                    margin-bottom: 16px;
                  "
                >
                  {{ code }}
                </div>
                {% endif %}

                {% if verification_url %}
                <div style="margin: 0 0 16px; text-align: center">
                  <a
                    class="verify-button"
                    href="{{ verification_url }}"
                    style="
                      background-color: #155eef;
                      color: #ffffff;
                      font-size: 16px;
                      font-weight: 600;
                      padding: 16px 32px;
                      border-radius: 8px;
                      text-decoration: none;
                      display: inline-block;
                      width: 100%;
                      text-align: center;
                      box-sizing: border-box;
                    "
                  >
                    Verify My Account
                  </a>
                </div>
                {% endif %}

                <p style="font-size: 14px; line-height: 22px; margin: 0 0 12px">
                  This code expires in {{ expiry_minutes }} minutes.
                </p>

                <p style="font-size: 14px; line-height: 22px; margin: 0 0 24px">
                  If you didn't create this account, you can safely ignore this
                  email.
                </p>

                <p style="font-size: 14px; line-height: 22px; margin: 0">
                  Stay healthy,
                  <br />
                  {{ app_name }} Team
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
