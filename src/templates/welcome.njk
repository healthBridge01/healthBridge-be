<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome to {{ app_name }}</title>
  </head>
  <body
    style="
      margin: 0;
      padding: 0;
      background-color: #f7f7f7;
      font-family: Arial, Helvetica, sans-serif;
    "
  >
    <table
      width="100%"
      cellpadding="0"
      cellspacing="0"
      border="0"
      style="padding: 24px 0"
    >
      <tr>
        <td align="center">
          <table
            width="100%"
            cellpadding="0"
            cellspacing="0"
            border="0"
            style="
              max-width: 600px;
              background: #ffffff;
              border-radius: 8px;
              padding: 24px;
            "
          >
            <tr>
              <td align="center" style="padding-bottom: 16px">
                <h2
                  style="
                    margin: 0;
                    font-size: 22px;
                    color: #1a1a1a;
                    font-weight: 700;
                  "
                >
                  Welcome to {{ app_name }}
                </h2>
              </td>
            </tr>
            <tr>
              <td style="font-size: 14px; color: #444444; line-height: 22px">
                <p style="margin: 0 0 12px 0">Hello {{ name }},</p>
                <p style="margin: 0 0 12px 0">
                  Thanks for signing in to {{ app_name }}. We're excited to help
                  you manage your health in one place.
                </p>
                <p style="margin: 0">
                  If you did not initiate this sign-in, please reset your
                  password or contact support.
                </p>
              </td>
            </tr>
            <tr>
              <td align="center" style="padding-top: 20px">
                <p style="margin: 0; font-size: 12px; color: #777777">
                  © {{ copyRightYear }} {{ app_name }}. All rights reserved.
                </p>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
