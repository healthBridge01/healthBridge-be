<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Welcome to {{ app_name }}</title>
    <style>
      @font-face {
        font-family: "Geist";
        font-style: normal;
        font-weight: 400;
        src: url("https://fonts.gstatic.com/s/geist/v1/cl8i4onL69kv55YcO2VhcQ.woff2")
          format("woff2");
      }
      @media only screen and (max-width: 600px) {
        .email-outer {
          padding: 0px !important;
        }
        .banner {
          font-size: 20px !important;
          padding: 16px 20px !important;
        }
        .content-section {
          padding: 20px !important;
        }
        .app-image {
          width: 100% !important;
          max-width: 100% !important;
        }
      }

      /* ── Dark mode ── */
      @media (prefers-color-scheme: dark) {
        .email-body {
          background-color: #111827 !important;
        }
        .email-outer {
          background-color: #1f2937 !important;
        }
        .logo-section {
          background-color: #1f2937 !important;
        }
        .content-section {
          background-color: #111827 !important;
        }
        .image-wrapper {
          background-color: #374151 !important;
        }
        .email-text {
          color: #f9fafb !important;
        }
        .logo-text {
          color: #ffffff !important;
        }
      }

      /* ── Light mode (explicit) ── */
      @media (prefers-color-scheme: light) {
        .email-body {
          background-color: #e5e7eb !important;
        }
        .email-outer {
          background-color: #ffffff !important;
        }
        .logo-section {
          background-color: #ffffff !important;
        }
        .content-section {
          background-color: #f6f6f6 !important;
        }
        .image-wrapper {
          background-color: #f3f4f6 !important;
        }
        .email-text {
          color: #374151 !important;
        }
        .logo-text {
          color: #000000 !important;
        }
      }
    </style>
  </head>
  <body
    class="email-body"
    style="
      background-color: #e5e7eb;
      margin: 0;
      padding: 0;
      font-family: Geist, 'Helvetica Neue', Helvetica, Arial, sans-serif;
      color: #111827;
    "
  >
    <table width="100%" cellpadding="0" cellspacing="0" border="0">
      <tr>
        <td align="center">
          <div
            style="
              display: none;
              max-height: 0px;
              overflow: hidden;
              mso-hide: all;
              font-size: 1px;
              line-height: 1px;
              color: #ffffff;
              opacity: 0;
            "
          >
            Welcome to {{ app_name }} — your account is ready!
          </div>
          <table
            width="100%"
            cellpadding="0"
            cellspacing="0"
            border="0"
            class="email-outer"
            style="
              max-width: 600px;
              margin: 0 auto;
              background-color: #ffffff;
            "
          >
            <tr>
              <td
                align="center"
                class="logo-section"
                style="padding: 30px 20px 20px; background-color: #ffffff"
              >
                <table cellpadding="0" cellspacing="0" border="0">
                  <tr>
                    <td align="center">
                      <img
                        alt="OHealth logo"
                        src="https://res.cloudinary.com/dvieev0ag/image/upload/v1771969746/logo_ezqram.png"
                        width="25"
                        style="display: inline-block; vertical-align: middle"
                      />
                      <span
                        class="logo-text"
                        style="
                          display: inline-block;
                          vertical-align: middle;
                          margin: 0 0 0 8px;
                          font-weight: 700;
                          font-size: 16px;
                          color: #000000;
                        "
                      >
                        {{ app_name }}
                      </span>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td align="center">
                <table
                  width="90%"
                  cellpadding="0"
                  cellspacing="0"
                  border="0"
                  style="
                    background-color: #155eef;
                    border-top-left-radius: 8px;
                    border-top-right-radius: 8px;
                  "
                >
                  <tr>
                    <td
                      class="banner"
                      align="center"
                      style="
                        color: #ffffff;
                        font-size: 22px;
                        font-weight: 700;
                        padding: 20px 32px;
                      "
                    >
                      Welcome to {{ app_name }}
                    </td>
                  </tr>
                </table>
              </td>
            </tr>

            <tr>
              <td align="center">
                <table
                  width="90%"
                  cellpadding="0"
                  cellspacing="0"
                  border="0"
                  class="content-section"
                  style="background-color: #f6f6f6; padding: 12px"
                >
                  <tr>
                    <td>
                      <p
                        class="email-text"
                        style="
                          font-size: 16px;
                          font-weight: 700;
                          margin: 0 0 8px;
                          color: #111827;
                        "
                      >
                        Hello {{ name }},
                      </p>

                      <p
                        class="email-text"
                        style="
                          font-size: 15px;
                          line-height: 24px;
                          margin: 0 0 16px;
                          color: #374151;
                        "
                      >
                        Your signup was successful, welcome to {{ app_name }}!
                      </p>

                      <table
                        width="70%"
                        cellpadding="0"
                        cellspacing="0"
                        border="0"
                        align="center"
                        class="image-wrapper"
                        style="
                          background-color: #f3f4f6;
                          border-radius: 12px;
                          padding: 20px;
                          margin: 8px auto 24px;
                        "
                      >
                        <tr>
                          <td style="padding-right: 10px" width="50%">
                            <img
                              alt="OHealth app screenshot 1"
                              src="https://res.cloudinary.com/duye4a3ff/image/upload/v1771321820/iPhone_14_15_Pro_-_2-2_bruevl.png"
                              width="100%"
                              class="app-image"
                              style="display: block; border-radius: 8px"
                            />
                          </td>
                          <td style="padding-left: 10px" width="50%">
                            <img
                              alt="OHealth app screenshot 2"
                              src="https://res.cloudinary.com/duye4a3ff/image/upload/v1771321999/iPhone_14_15_Pro_-_1_bzquso.png"
                              width="100%"
                              class="app-image"
                              style="display: block; border-radius: 8px"
                            />
                          </td>
                        </tr>
                      </table>

                      <p
                        class="email-text"
                        style="
                          font-size: 15px;
                          line-height: 24px;
                          margin: 0 0 16px;
                          color: #374151;
                        "
                      >
                        We're here to make accessing healthcare simpler, safer,
                        and more convenient for you. You can now book
                        appointments, connect with healthcare professionals, and
                        manage your health records all in one place.
                      </p>

                      <p
                        class="email-text"
                        style="
                          font-size: 15px;
                          line-height: 24px;
                          margin: 0 0 16px;
                          color: #374151;
                        "
                      >
                        If you need any help getting started, we're always here
                        for you.
                      </p>

                      <p
                        class="email-text"
                        style="
                          font-size: 14px;
                          line-height: 22px;
                          margin: 8px 0 0;
                          color: #374151;
                        "
                      >
                        Stay well,
                        <br />
                        {{ app_name }} Team
                      </p>
                    </td>
                  </tr>
                </table>
              </td>
            </tr>
          </table>
        </td>
      </tr>
    </table>
  </body>
</html>
